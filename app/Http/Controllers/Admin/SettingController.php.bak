    /**
     * Update the payment settings.
     *
     * @param  \Illuminate\Http\Request  $request
     * @return \Illuminate\Http\RedirectResponse
     */
    public function updatePayment(Request $request)
    {
        $validated = $request->validate([
            // Stripe
            'stripe_key' => ['nullable', 'string'],
            'stripe_secret' => ['nullable', 'string'],
            'stripe_webhook_secret' => ['nullable', 'string'],
            
            // GCash
            'gcash_account_name' => ['nullable', 'string', 'max:255'],
            'gcash_mobile_number' => ['nullable', 'string', 'max:20'],
            'gcash_qr_code' => ['nullable', 'string'],
            
            // Currency
            'currency' => ['required', 'string', 'size:3'],
            'currency_symbol' => ['required', 'string', 'max:5'],
            'currency_format' => ['required', 'in:left,right'],
            
            // Commission
            'commission_rate' => ['required', 'numeric', 'min:0', 'max:100'],
            'minimum_payout' => ['required', 'numeric', 'min:0'],
        ]);

        // Update Stripe settings
        $this->updateEnvValue('STRIPE_KEY', $validated['stripe_key'] ?? '');
        $this->updateEnvValue('STRIPE_SECRET', $validated['stripe_secret'] ?? '');
        $this->updateEnvValue('STRIPE_WEBHOOK_SECRET', $validated['stripe_webhook_secret'] ?? '');
        
        // Update GCash settings
        $this->updateEnvValue('GCASH_ACCOUNT_NAME', $validated['gcash_account_name'] ?? '');
        $this->updateEnvValue('GCASH_MOBILE_NUMBER', $validated['gcash_mobile_number'] ?? '');
        $this->updateEnvValue('GCASH_QR_CODE', $validated['gcash_qr_code'] ?? '');
        
        // Update currency settings
        $this->updateEnvValue('CASHIER_CURRENCY', $validated['currency']);
        $this->updateEnvValue('CASHIER_CURRENCY_SYMBOL', $validated['currency_symbol']);
        $this->updateEnvValue('CASHIER_CURRENCY_FORMAT', $validated['currency_format']);
        
        // Update commission settings
        $this->updateEnvValue('COMMISSION_RATE', $validated['commission_rate']);
        $this->updateEnvValue('MINIMUM_PAYOUT', $validated['minimum_payout']);
    
    // Clear config cache
    \Artisan::call('config:clear');
    \Artisan::call('config:cache');
    
    return redirect()
        ->route('admin.settings.payment')
        ->with('success', 'Payment settings updated successfully!');
}

